                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const roles = pm.response.json().data || [];",
                  "  roles.forEach(role => pm.environment.set(role.name.toLowerCase() + 'RoleId', role.id));",
